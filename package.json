{
  "name": "terminal-setup-style",
  "displayName": "Terminal-Setup-Style",
  "description": "Terminal Setup Style by Angel Eduardo Tarcaya",
  "version": "0.0.5",
  "publisher": "angel-t-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/angeltarcayadev/Terminal-Setup.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminal-setup-style.install",
        "title": "Angel-T Dev: Instalar Terminal Setup"
      }
    ],
    "configuration": {
      "title": "Terminal Setup Style",
      "properties": {
        "terminalSetup.nombre": {
          "type": "string",
          "default": "Angel-T Dev",
          "description": "Nombre que aparecerá en tu terminal."
        },
        "terminalSetup.fuente": {
          "type": "string",
          "default": "FiraCode Nerd Font Mono",
          "description": "Nombre de la fuente (debe estar instalada)."
        },
        "terminalSetup.tema": {
          "type": "string",
          "default": "angel-default",
          "enum": [
            "angel-default",
            "angel-cyberpunk",
            "angel-dracula",
            "angel-hacker",
            "angel-tokyo",
            "angel-monokai",
            "angel-ocean",
            "angel-synthwave",
            "angel-gruvbox",
            "angel-minimal"
          ],
          "description": "Selecciona tu tema favorito."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
